{
  "manifest_version": 3,
  "name": "LeadLens",
  "version": "1.0.0",
  "description": "Save Instagram influencer/prospect data directly into Google Sheets. Auto-scrape profile data, classify by follower tier, and build your lead list.",
  "permissions": [
    "identity",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://sheets.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "19984992940-1ki4hmavg0gfj2av8mb7a9cslsvnt3vj.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "content/scraper.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "LeadLens — Save Instagram Leads"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}